rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---
    
    function isValidUserProfile(data) {
      return data.userId is string && data.userId == request.auth.uid;
    }

    function isValidIncome(data) {
      return (data.amount is number) &&
             (data.source is string) &&
             (data.userId == request.auth.uid);
    }

    function isValidExpense(data) {
      return (data.amount is number) &&
             (data.source is string) &&
             (data.userId == request.auth.uid);
    }

    function isValidInvoice(data) {
      return (data.title is string) &&
             (data.imageUrl is string) &&
             (data.userId == request.auth.uid);
    }

    function isValidWishlist(data) {
      return (data.name is string) && (data.name.size() > 0) &&
             (data.price is number) &&
             (data.userId == request.auth.uid);
    }

    function isValidImpulseCheck(data) {
      return (data.name is string) &&
             (data.price is number) &&
             (data.userId == request.auth.uid);
    }

    function isValidOffDay(data) {
      return (data.date is string) &&
             (data.userId == request.auth.uid);
    }

    function isValidSalesRecap(data) {
      return (data.customerName is string) &&
             (data.booth is string) &&
             (data.items is list) &&
             (data.fee is number) &&
             (data.userId == request.auth.uid);
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming());

      match /incomes/{incomeId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidIncome(incoming());
        allow update: if isOwner(userId) && isValidIncome(incoming());
        allow delete: if isOwner(userId);
      }

      match /expenses/{expenseId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidExpense(incoming());
        allow update: if isOwner(userId) && isValidExpense(incoming());
        allow delete: if isOwner(userId);
      }

      match /invoices/{invoiceId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidInvoice(incoming());
        allow update: if isOwner(userId) && isValidInvoice(incoming());
        allow delete: if isOwner(userId);
      }

      match /wishlist/{wishlistId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWishlist(incoming());
        allow update: if isOwner(userId) && isValidWishlist(incoming());
        allow delete: if isOwner(userId);
      }

      match /impulseChecks/{checkId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidImpulseCheck(incoming());
        allow update: if isOwner(userId) && isValidImpulseCheck(incoming());
        allow delete: if isOwner(userId);
      }

      match /offDays/{offDayId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOffDay(incoming());
        allow update: if isOwner(userId) && isValidOffDay(incoming());
        allow delete: if isOwner(userId);
      }

      match /salesRecap/{saleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSalesRecap(incoming());
        allow update: if isOwner(userId) && isValidSalesRecap(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
